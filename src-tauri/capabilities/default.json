{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPLOG/**" },
        { "path": "$TEMP/**" }
      ]
    },
    "core:webview:allow-create-webview-window",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:webview:allow-webview-close",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$HOME/**" }
      ]
    }
  ]
}
